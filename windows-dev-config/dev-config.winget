  dependsOn:
  - ElevationCheck
  properties:
    keyPath: HKCU\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\Advanced
    valueName: ShowSyncProviderNotifications
    valueData:
      DWord: 0
    _exist: true
